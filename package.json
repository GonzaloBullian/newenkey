{
  "name": "newenkey",
  "version": "1.0.0",
  "description": "NewenKey — Hotkeys + Text Expansion · by gbull",
  "main": "main.js",
  "author": "gbull",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "package:win": "vite build && electron-builder --win",
    "package:mac": "vite build && electron-builder --mac",
    "package:all": "vite build && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.gbull.newenkey",
    "productName": "NewenKey",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "main.js", "preload.js", "assets/**/*", "node_modules/uiohook-napi/**/*"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }], "icon": "assets/icon.ico" },
    "nsis": { "oneClick": false, "perMachine": false, "allowToChangeInstallationDirectory": true },
    "mac": { "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }], "icon": "assets/icon.icns", "category": "public.app-category.productivity" }
  },
  "dependencies": { "uiohook-napi": "^1.5.4" },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1", "autoprefixer": "^10.4.17", "concurrently": "^8.2.2",
    "cross-env": "^7.0.3", "electron": "^28.1.0", "electron-builder": "^24.9.1",
    "postcss": "^8.4.33", "react": "^18.2.0", "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1", "vite": "^5.0.12", "wait-on": "^7.2.0"
  }
}
